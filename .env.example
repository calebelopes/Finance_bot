# Required: Telegram bot token from @BotFather
TOKEN=your_telegram_bot_token_here

# Optional: comma-separated Telegram user IDs allowed to use the bot.
# Leave empty or unset to allow all users.
ALLOWED_USERS=

# Optional: Telegram user ID of the bot owner (can run /admin to manage the dashboard admin panel)
BOT_OWNER=

# Optional: timezone for date/time display (default: America/Sao_Paulo)
TIMEZONE=America/Sao_Paulo

# Optional: use OS trust store for TLS (useful on corporate networks)
# USE_SYSTEM_CA=1

# Optional: path to a custom CA bundle PEM file
# TELEGRAM_CA_BUNDLE=/path/to/ca-bundle.pem

# Dashboard URL shown to users in bot messages
DASHBOARD_URL=http://localhost:8501
