# =============================================================================
# Telegram bot (optional — the web app works on its own)
# =============================================================================

# Telegram bot token from @BotFather. Required only if you want to run the bot.
TOKEN=your_telegram_bot_token_here

# Bot's @username (without the @). Used by the web app to build the
# t.me/<username>?start=link_CODE deep link on the "Link Telegram" flow.
# Defaults to "Folhinha_bot" (the bot this project ships with). Override
# this only if you're running a fork against a different bot.
# BOT_USERNAME=Folhinha_bot

# Optional: comma-separated Telegram user IDs allowed to use the bot.
# Leave empty or unset to allow all users.
ALLOWED_USERS=

# Optional: Telegram user ID of the bot owner (can run /admin to manage the dashboard admin panel)
BOT_OWNER=

# Optional: use OS trust store for TLS (useful on corporate networks)
# USE_SYSTEM_CA=1

# Optional: path to a custom CA bundle PEM file
# TELEGRAM_CA_BUNDLE=/path/to/ca-bundle.pem

# =============================================================================
# Web app (FastAPI / uvicorn)
# =============================================================================

# Port the web app listens on (default 8000)
WEB_PORT=8000

# Public URL of the web app — used by bot messages that point users
# to the website (registration, dashboard, settings, etc.).
WEB_URL=http://localhost:8000

# =============================================================================
# Shared
# =============================================================================

# Default timezone used when a user has no preference set yet
TIMEZONE=America/Sao_Paulo
